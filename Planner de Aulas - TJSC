  // W0 usa day=5(Sáb) e day=6(Dom) — os demais dias de W0 NÃO existem
  const rows = [
    // ── W0  Sáb 02/05 + Dom 03/05 ──
    [0,5,'lp',0,  'ag',0,  'am',0 ],  // Sáb(3): content×3
    [0,6,'li',0                   ],  // Dom(1): content

    // ── W1  Seg 04 → Dom 10 Mai ──
    [1,0,'li',1,  'afo',0         ],  // Seg(2)
    [1,1,'lp',1,  'ag',1,  'am',1 ],  // Ter(3): content×3
    [1,2,'et',0,  'inf',0         ],  // Qua(2): no LP+INF ✓
    [1,3,'li',2,  'afo',2, 'et',1 ],  // Qui(3): et1=SIM ✓
    [1,4,'lp',2,  'gp',0          ],  // Sex(2)
    [1,5,'ag',2,  'inf',1, 'dh',0 ],  // Sáb(3): content×3
    [1,6,'li',3                   ],  // Dom(1)

    // ── W2  Seg 11 → Dom 17 Mai ──
    [2,0,'afo',3, 'lp',3          ],  // Seg(2)
    [2,1,'li',4,  'ag',3,  'inf',2],  // Ter(3): content×3
    [2,2,'et',2,  'am',2          ],  // Qua(2)
    [2,3,'li',5,  'afo',4, 'ap',0 ],  // Qui(3): content×3
    [2,4,'lp',4,  'gp',1          ],  // Sex(2): lp4=SIM1 ✓
    [2,5,'ag',4,  'dh',1,  'ap',1 ],  // Sáb(3): ag4=SIM ✓
    [2,6,'li',6                   ],  // Dom(1)

    // ── W3  Seg 18 → Dom 24 Mai ──
    [3,0,'afo',5, 'lp',5          ],  // Seg(2): afo5=SIM ✓
    [3,1,'li',7,  'et',3,  'inf',3],  // Ter(3): inf3=SIM ✓
    [3,2,'am',3,  'ap',3          ],  // Qua(2): am3=SIM ✓
    [3,3,'li',8,  'afo',6, 'ap',2 ],  // Qui(3): ap2=SIM ✓
    [3,4,'lp',6,  'et',4          ],  // Sex(2): et4=SIM ✓
    [3,5,'gp',2,  'ag',5,  'dh',3 ],  // Sáb(3): gp2=SIM ✓
    [3,6,'li',9                   ],  // Dom(1)

    // ── W4  Seg 25 Mai → Dom 31 Mai ──
    [4,0,'afo',7, 'lp',7          ],  // Seg(2)
    [4,1,'li',10, 'dh',2,  'ag',6 ],  // Ter(3): dh2=SIM ✓
    [4,2,'et',5,  'am',4          ],  // Qua(2)
    [4,3,'li',11, 'afo',8, 'ap',4 ],  // Qui(3): afo8=SIM ✓
    [4,4,'lp',8,  'gp',3          ],  // Sex(2)
    [4,5,'ag',7,  'inf',4, 'et',6 ],  // Sáb(3): content×3
    [4,6,'li',12                  ],  // Dom(1)

    // ── W5  Seg 01 → Dom 07 Jun ──
    [5,0,'afo',9, 'lp',9          ],  // Seg(2): lp9=SIM2 ✓
    [5,1,'li',13, 'et',7,  'inf',5],  // Ter(3): et7=SIM ✓
    [5,2,'am',5,  'ap',5          ],  // Qua(2)
    [5,3,'li',14, 'afo',10,'gp',4 ],  // Qui(3): content×3
    [5,4,'lp',10, 'gp',5          ],  // Sex(2)
    [5,5,'inf',6, 'dh',4,  'am',6 ],  // Sáb(3): no LP ✓
    [5,6,'li',15                  ],  // Dom(1)

    // ── W6  Seg 08 → Dom 14 Jun ──
    [6,0,'afo',11,'lp',11         ],  // Seg(2)
    [6,1,'li',16, 'afo',12,'am',7 ],  // Ter(3): afo12=SIM ✓
    [6,2,'gp',6,  'et',8          ],  // Qua(2): gp6=SIM ✓
    [6,3,'lp',12, 'li',17, 'afo',13], // Qui(3): lp12=SIM3 ✓ (no INF ✓)
    [6,4,'ag',8,  'li',18         ],  // Sex(2): ag8=SIM ✓
    [6,5,'tc',0,  'inf',7, 'dh',5 ],  // Sáb(3): dh5=SIM ✓ (no LP ✓)
    [6,6,'ap',6                   ],  // Dom(1): ap6=SIM ✓

    // ── W7  Seg 15 → Dom 21 Jun ──
    [7,0,'li',19, 'am',8          ],  // Seg(2): am8=SIM ✓
    [7,1,'li',20, 'afo',1, 'et',9 ],  // Ter(3): et9=SIM ✓
    [7,2,'afo',14,'inf',8         ],  // Qua(2): inf8=SIM ✓ (no LP ✓)
    [7,3,'li',21, 'afo',15,'tc',1 ],  // Qui(3): tc1=SIM ✓
    [7,4,'afo',17                 ],  // Sex(2): afo17=SIM ✓ (1 slot livre)
    [7,6,'afo',16                 ],  // Dom(1): content
  ];

  // Converte rows para schedule[week][day] = [{mat,idx}]
  // day: 0=Seg..5=Sáb..6=Dom (igual ao índice da row)
  const schedule = Array.from({length:9}, ()=>Array.from({length:7}, ()=>[]));
  rows.forEach(row => {
    const w=row[0], d=row[1];
    for(let i=2; i<row.length; i+=2) schedule[w][d].push({mat:row[i], idx:row[i+1]});
  });
  schedule.push(null); // W8 = revisão
  return schedule;
}
const RAW_SCHEDULE = buildSchedule();

// Build lesson objects from schedule
function buildLessons(){
  const arr = [];
  let id = 1;
  RAW_SCHEDULE.forEach((wk, wi) => {
    if(!wk) return; // revision week
    wk.forEach((day, di) => {
      day.forEach(slot => {
        const lesson = ALL_LESSONS[slot.mat][slot.idx];
        arr.push({
          id: id++,
          mat: slot.mat,
          lessonNum: lesson.n,
          title: lesson.t,
          importance: lesson.inc,
          isSimulado: !!lesson.sim,
          week: wi,
          day: di,
          status: 'Não Iniciado',
          method: 'Aula',
        });
      });
    });
  });
  return arr;
}

