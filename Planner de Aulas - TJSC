function fmt(d){ return `${d.getDate().toString().padStart(2,'0')}/${(d.getMonth()+1).toString().padStart(2,'0')}`; }
function mat(id){ return MATS.find(m=>m.id===id)||{name:id,color:'#888'}; }
function statusClass(s){ return s==='Não Iniciado'?'s-nao':s==='Iniciado'?'s-ini':s==='Revisar'?'s-rev':'s-fin'; }
const DAY_NAMES = ['Segunda','Terça','Quarta','Quinta','Sexta','Sábado','Domingo'];

// Get lessons taught day before (for revision block)
function getPrevDayLessons(week, day){
  let pw = week, pd = day-1;
  if(pd < 0){ pw--; pd = 5; }
  if(pw < 0) return [];
  return lessons.filter(l => l.week===pw && l.day===pd && !l.isSimulado).slice(0,3);
}
// Get key topics from previous week for revision
function getPrevWeekSummary(week){
  if(week===0) return [];
  const prev = lessons.filter(l => l.week===week-1 && !l.isSimulado);
  const mats = [...new Set(prev.map(l=>l.mat))];
  return mats.slice(0,4);
}

