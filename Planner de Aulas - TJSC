        ${revHtml}
        ${lessonsHtml || '<div style="font-size:11px;color:var(--text3);text-align:center;padding:8px">Sem aulas planejadas</div>'}
      </div>
    </div>`;
  }
  html += '</div>';
  document.getElementById('days-view').innerHTML = html;
}

function cycleStatus(id){
  const l = lessons.find(x=>x.id===id);
  if(!l) return;
  const order = ['Não Iniciado','Iniciado','Revisar','Finalizado'];
  const i = order.indexOf(l.status);
  l.status = order[(i+1)%order.length];
  saveLessons();
  renderDays();
  renderStats();
}

