// TEMPO TAB
// ═══════════════════════════════════════════════
function renderTempo(){
  let html = '';
  WEEKS_META.forEach((w, wi) => {
    const wkDays = [];
    for(let di=0;di<6;di++){
      const dayLessons = lessons.filter(l=>l.week===wi&&l.day===di);
      const mids = [...new Set(dayLessons.map(l=>l.mat))];
      if(w.revision) {
        // Calculate real date for this day slot
    // For W0 (starts Sat): di=5→Sáb 02/05, di=6→Dom 03/05
    // For W1+: di=0→Seg (w.start+0), ..., di=6→Dom (w.start+6)
    let dayOffset = di;
    if(curWeek===0){ dayOffset = di - 5; } // Sáb=5→offset0, Dom=6→offset1
    const dayDate = new Date(w.start); dayDate.setDate(w.start.getDate()+dayOffset);
    const realDayName = ['Domingo','Segunda','Terça','Quarta','Quinta','Sexta','Sábado'][dayDate.getDay()];
        wkDays.push({di, mids:['revisao'], date:dayDate});
      } else {
        // Calculate real date for this day slot
    // For W0 (starts Sat): di=5→Sáb 02/05, di=6→Dom 03/05
    // For W1+: di=0→Seg (w.start+0), ..., di=6→Dom (w.start+6)
    let dayOffset = di;
    if(curWeek===0){ dayOffset = di - 5; } // Sáb=5→offset0, Dom=6→offset1
    const dayDate = new Date(w.start); dayDate.setDate(w.start.getDate()+dayOffset);
    const realDayName = ['Domingo','Segunda','Terça','Quarta','Quinta','Sexta','Sábado'][dayDate.getDay()];
        wkDays.push({di, mids: mids.length?mids:['—'], date:dayDate});
      }
    }
    // Sunday
    const sunDate = new Date(w.start); sunDate.setDate(w.start.getDate()+6);
    wkDays.push({di:6, mids:['simulado'], date:sunDate});

    const wkTotal = wkDays.reduce((acc,d)=>{
      return acc + d.mids.reduce((a,mid)=>{
        const v=(tempoData[`${wi}_${d.di}_${mid}`]||{}).horas||'';
        return a+(v?parseH(v):0);
      },0);
    },0);

    html += `<div class="tempo-week">
      <div class="tempo-week-head" onclick="toggleC(this)">
        <div class="tempo-week-name">${w.label}</div>
        <div style="display:flex;align-items:center;gap:10px">
          <div class="tempo-week-total">Total: ${fmtH(wkTotal)}</div>
          <span class="collapse-arrow">▾</span>
        </div>
      </div>
      <div class="tempo-week-body">
        ${wkDays.map(d => {
          const dayTotal = d.mids.reduce((a,mid)=>{
            const v=(tempoData[`${wi}_${d.di}_${mid}`]||{}).horas||'';
            return a+(v?parseH(v):0);
          },0);
          const matNames = d.mids.map(mid => {
            if(mid==='simulado') return {name:'Simulado/Revisão',color:'#f87171'};
            if(mid==='revisao') return {name:'Revisão Geral',color:'#c084fc'};
            if(mid==='—') return {name:'—',color:'var(--text3)'};
            const m = mat(mid); return {name:m.name, color:m.color};
          });
          return `<div class="tempo-day-block">
            <div class="tempo-day-head">
              <span class="tempo-day-nm">${DAY_NAMES[d.di]} · ${fmt(d.date)}</span>
              <span class="tempo-day-tot">Total: ${fmtH(dayTotal)}</span>
            </div>
            <div class="tempo-entry-wrap">
              <div class="tempo-col-heads">
                <span class="tempo-col-head">Disciplina</span>
                <span class="tempo-col-head">Horas</span>
                <span class="tempo-col-head">Questões</span>
                <span class="tempo-col-head">Erros</span>
                <span class="tempo-col-head">Acerto</span>
              </div>
              ${d.mids.map((mid,mi)=>{
                if(mid==='—') return '';
                const tkey=`${wi}_${d.di}_${mid}`;
                const td=tempoData[tkey]||{};
                const pct=calcAc(td.questoes,td.erros);
                const pcls=pct===null?'ac-non':pct<70?'ac-red':pct<=80?'ac-yel':'ac-grn';
                const ptxt=pct===null?'—':`${pct}%`;
                return `<div class="tempo-row">
                  <div class="tempo-mat-lbl" style="color:${matNames[mi].color}">${matNames[mi].name}</div>
                  <input class="tempo-inp" type="text" placeholder="00:00h" value="${td.horas||''}" oninput="saveTmpo('${tkey}','horas',this.value)" />
                  <input class="tempo-inp" type="number" min="0" placeholder="0" value="${td.questoes||''}" oninput="saveTmpo('${tkey}','questoes',this.value)" />
                  <input class="tempo-inp" type="number" min="0" placeholder="0" value="${td.erros||''}" oninput="saveTmpo('${tkey}','erros',this.value)" />
                  <div class="acerto-badge ${pcls}" id="ac-${tkey.replace(/[^a-z0-9]/gi,'_')}">${ptxt}</div>
                </div>`;
              }).join('')}
            </div>
          </div>`;
        }).join('')}
      </div>
    </div>`;
  });
  document.getElementById('tempo-content').innerHTML = html;
}

function saveTmpo(key,field,val){
  if(!tempoData[key]) tempoData[key]={};
  tempoData[key][field]=val;
  saveTempo();
  const td=tempoData[key];
  const pct=calcAc(td.questoes,td.erros);
  const pcls=pct===null?'ac-non':pct<70?'ac-red':pct<=80?'ac-yel':'ac-grn';
  const ptxt=pct===null?'—':`${pct}%`;
  const bid=`ac-${key.replace(/[^a-z0-9]/gi,'_')}`;
  const el=document.getElementById(bid);
  if(el){el.textContent=ptxt;el.className=`acerto-badge ${pcls}`;}
}

function calcAc(q,e){
  q=parseInt(q);e=parseInt(e);
  if(isNaN(q)||q<=0) return null;
  if(isNaN(e)) e=0;
  return Math.round((q-e)/q*100);
}
function parseH(s){
  if(!s) return 0;
  s=s.replace('h','').trim();
  const [h,m]=s.split(':').map(Number);
  return (h||0)+(m||0)/60;
}
function fmtH(h){
  if(!h) return '0:00h';
  const hh=Math.floor(h), mm=Math.round((h-hh)*60);
  return `${hh}:${mm.toString().padStart(2,'0')}h`;
}

function toggleC(head){ head.parentElement.classList.toggle('collapsed'); }

