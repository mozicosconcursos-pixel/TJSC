          </div>
        </div>
      </div>`;
    }).join('');

    const cardClass = isSun ? 'day-card sunday-card' : 'day-card';
    const dayIcon = isSun ? '🎯 ' : '';
    const badgeStyle = isSun ? ' style="background:rgba(248,113,113,.15);color:#f87171"' : '';

    html += `<div class="${cardClass}">
