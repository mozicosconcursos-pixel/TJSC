              <button class="kb-icon-btn" onclick="openDel(${l.id})">🗑️</button>
            </div>
          </div>`;
        }).join('')}
      </div>
      <button class="add-card-btn" onclick="openAdd()">+ Nova aula</button>
    </div>`;
  });
  html += '</div>';
  document.getElementById('kanban-view').innerHTML = html;
}

function dStart(e,id){ dragId=id; e.dataTransfer.effectAllowed='move'; }
function dOver(e){ e.preventDefault(); }
function dDrop(e,st){ e.preventDefault(); if(dragId){ updateStatus(dragId,st); dragId=null; } }

function updateStatus(id,st){
  const l=lessons.find(x=>x.id===id);
  if(l){l.status=st;saveLessons();}
  if(curView==='kanban') renderKanban(); else renderDays();
  renderStats();
}
function updateMethod(id,m){
  const l=lessons.find(x=>x.id===id);
  if(l){l.method=m;saveLessons();}
}

