<!DOCTYPE html>

<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Planner de Aulas TJSC 2026 — Analista Administrativo</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0c10;
  --surface: #11141c;
  --surface2: #181d28;
  --surface3: #1f2535;
  --border: #252d42;
  --border2: #2e3855;
  --text: #eaecf5;
  --text2: #8e96b4;
  --text3: #4a5272;

–lp:   #60a5fa;
–li:   #a78bfa;
–et:   #34d399;
–inf:  #fb923c;
–dh:   #f472b6;
–ag:   #fbbf24;
–gp:   #38bdf8;
–am:   #4ade80;
–ap:   #f87171;
–afo:  #fb7185;
–tc:   #c084fc;

–radius: 14px;
–radius-sm: 9px;
–radius-xs: 6px;
}

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
font-family: ‘DM Sans’, sans-serif;
background: var(–bg);
color: var(–text);
min-height: 100vh;
}

/* ── HEADER ── */
.header {
background: var(–surface);
border-bottom: 1px solid var(–border);
padding: 14px 24px;
display: flex;
align-items: center;
justify-content: space-between;
position: sticky;
top: 0;
z-index: 200;
gap: 16px;
}
.header-left { display: flex; align-items: center; gap: 14px; }
.logo-mark {
width: 36px; height: 36px;
background: linear-gradient(135deg, #60a5fa, #a78bfa);
border-radius: 10px;
display: flex; align-items: center; justify-content: center;
font-family: ‘Outfit’, sans-serif;
font-weight: 900; font-size: 16px; color: #000;
flex-shrink: 0;
}
.header-title { font-family: ‘Outfit’, sans-serif; font-weight: 800; font-size: 17px; }
.header-sub { font-size: 11px; color: var(–text3); margin-top: 1px; }

.countdown {
display: flex; align-items: center; gap: 12px;
background: linear-gradient(135deg, #c0392b 0%, #e74c3c 100%);
border-radius: var(–radius-sm);
padding: 8px 16px;
}
.cd-block { text-align: center; }
.cd-num { font-family: ‘Outfit’, sans-serif; font-weight: 900; font-size: 26px; color: #fff; line-height: 1; }
.cd-lbl { font-size: 10px; color: rgba(255,255,255,0.65); font-family: ‘Outfit’,sans-serif; text-transform: uppercase; letter-spacing: 0.06em; }
.cd-sep { font-size: 18px; color: rgba(255,255,255,0.4); font-weight: 300; }
.cd-date { font-size: 11px; color: rgba(255,255,255,0.7); }

/* ── TABS ── */
.tabs-nav {
background: var(–surface);
border-bottom: 1px solid var(–border);
padding: 0 24px;
display: flex; gap: 2px;
overflow-x: auto;
}
.tab-btn {
font-family: ‘Outfit’, sans-serif; font-weight: 600; font-size: 13px;
padding: 13px 16px;
background: none; border: none; border-bottom: 2px solid transparent;
color: var(–text3); cursor: pointer; white-space: nowrap;
transition: all .2s;
}
.tab-btn:hover { color: var(–text2); }
.tab-btn.active { color: var(–text); border-bottom-color: #60a5fa; }

.tab-pane { display: none; padding: 24px; }
.tab-pane.active { display: block; }

/* ── WEEK SELECTOR ── */
.week-selector {
display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 18px;
}
.wk-btn {
font-family: ‘Outfit’,sans-serif; font-size: 11px; font-weight: 700;
padding: 5px 13px; border-radius: 20px;
border: 1px solid var(–border2);
background: var(–surface2); color: var(–text3);
cursor: pointer; transition: all .2s; white-space: nowrap;
}
.wk-btn:hover { border-color: #60a5fa; color: var(–text2); }
.wk-btn.active { background: #60a5fa; border-color: #60a5fa; color: #000; }
.wk-btn.revision { background: linear-gradient(135deg,#f97316,#ef4444); border-color: transparent; color: #fff; }

/* ── VIEW TOGGLE ── */
.view-row {
display: flex; align-items: center; justify-content: space-between;
margin-bottom: 18px;
}
.view-toggle { display: flex; gap: 6px; }
.vt-btn {
font-family: ‘Outfit’,sans-serif; font-size: 12px; font-weight: 600;
padding: 6px 14px; border-radius: var(–radius-xs);
border: 1px solid var(–border2); background: var(–surface2);
color: var(–text3); cursor: pointer; transition: all .2s;
}
.vt-btn.active { background: var(–surface3); border-color: #60a5fa; color: var(–text); }
.btn-add {
font-family: ‘Outfit’,sans-serif; font-weight: 700; font-size: 12px;
padding: 7px 16px; background: #60a5fa; color: #000;
border: none; border-radius: var(–radius-xs); cursor: pointer;
transition: .2s;
}
.btn-add:hover { background: #93c5fd; }

/* ── DAY GRID ── */
.day-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
gap: 14px;
}
.day-card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: var(–radius);
overflow: hidden;
}
.day-header {
padding: 12px 16px;
background: var(–surface2);
border-bottom: 1px solid var(–border);
display: flex; justify-content: space-between; align-items: flex-start;
}
.day-name { font-family: ‘Outfit’,sans-serif; font-weight: 700; font-size: 14px; }
.day-date { font-size: 11px; color: var(–text3); margin-top: 2px; }
.day-badge {
font-family: ‘Outfit’,sans-serif; font-size: 10px; font-weight: 700;
padding: 3px 8px; border-radius: 4px;
background: var(–surface3); color: var(–text2);
flex-shrink: 0;
}

/* lesson items inside day */
.day-body { padding: 10px 12px; display: flex; flex-direction: column; gap: 6px; }

.lesson-item {
border-radius: var(–radius-xs);
border: 1px solid var(–border);
overflow: hidden;
}
.lesson-type-bar { /* left colored strip */ }

.lesson-inner {
display: flex; gap: 10px; align-items: flex-start; padding: 9px 10px;
}
.lesson-left-strip {
width: 3px; border-radius: 2px; align-self: stretch; flex-shrink: 0;
}
.lesson-content { flex: 1; min-width: 0; }
.lesson-mat-tag {
font-family: ‘Outfit’,sans-serif; font-size: 10px; font-weight: 700;
text-transform: uppercase; letter-spacing: 0.05em;
margin-bottom: 3px;
}
.lesson-title {
font-size: 12px; color: var(–text); line-height: 1.4;
font-weight: 500;
}
.lesson-sub {
font-size: 11px; color: var(–text3); margin-top: 2px;
}
.lesson-footer {
display: flex; align-items: center; gap: 5px; margin-top: 6px; flex-wrap: wrap;
}
.badge-imp {
font-family: ‘Outfit’,sans-serif; font-size: 9px; font-weight: 700;
padding: 1px 6px; border-radius: 3px;
}
.imp-Alta { background: rgba(248,113,113,.18); color: #f87171; border:1px solid rgba(248,113,113,.25); }
.imp-Média { background: rgba(251,191,36,.18); color: #fbbf24; border:1px solid rgba(251,191,36,.25); }
.imp-Baixa { background: rgba(74,222,128,.18); color: #4ade80; border:1px solid rgba(74,222,128,.25); }

.badge-type {
font-family: ‘Outfit’,sans-serif; font-size: 9px; font-weight: 700;
padding: 1px 6px; border-radius: 3px;
background: rgba(96,165,250,.15); color: #60a5fa; border:1px solid rgba(96,165,250,.25);
}
.badge-simulado {
background: rgba(251,146,60,.15); color: #fb923c; border:1px solid rgba(251,146,60,.25);
}
.badge-rev {
background: rgba(196,132,252,.15); color: #c084fc; border:1px solid rgba(196,132,252,.25);
}

.lesson-actions { display: flex; gap: 4px; margin-left: auto; }
.icon-btn {
background: none; border: none; cursor: pointer;
font-size: 12px; opacity: 0.4; transition: opacity .2s; padding: 2px;
}
.icon-btn:hover { opacity: 1; }

.status-pill {
font-family: ‘Outfit’,sans-serif; font-size: 9px; font-weight: 700;
padding: 2px 7px; border-radius: 10px; cursor: pointer;
transition: all .2s; border: 1px solid;
}
.s-nao { background: rgba(90,96,128,.2); color: var(–text3); border-color: var(–border2); }
.s-ini { background: rgba(96,165,250,.18); color: #60a5fa; border-color: rgba(96,165,250,.3); }
.s-rev { background: rgba(251,191,36,.18); color: #fbbf24; border-color: rgba(251,191,36,.3); }
.s-fin { background: rgba(74,222,128,.18); color: #4ade80; border-color: rgba(74,222,128,.3); }

/* revision block inside day */
.rev-block {
border-radius: var(–radius-xs);
background: rgba(196,132,252,.07);
border: 1px solid rgba(196,132,252,.2);
padding: 8px 10px;
font-size: 11px; color: var(–text3);
line-height: 1.5;
}
.rev-block strong { color: #c084fc; font-family: ‘Outfit’,sans-serif; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 3px; }

/* sunday */
.sunday-card {
background: linear-gradient(135deg, rgba(248,113,113,.08), rgba(251,146,60,.05));
border-color: rgba(248,113,113,.2);
}
.sunday-inner { padding: 16px; text-align: center; }
.sunday-icon { font-size: 32px; margin-bottom: 8px; }
.sunday-title { font-family: ‘Outfit’,sans-serif; font-weight: 700; font-size: 14px; color: #f87171; }
.sunday-sub { font-size: 12px; color: var(–text3); margin-top: 4px; }

/* ── KANBAN ── */
.kanban-wrap { display: flex; gap: 14px; overflow-x: auto; padding-bottom: 8px; }
.kb-col {
min-width: 270px; background: var(–surface);
border: 1px solid var(–border); border-radius: var(–radius);
padding: 14px; flex-shrink: 0;
}
.kb-col-head {
font-family: ‘Outfit’,sans-serif; font-weight: 700; font-size: 12px;
text-transform: uppercase; letter-spacing: .08em;
margin-bottom: 12px; display: flex; align-items: center; gap: 7px;
}
.kb-dot { width: 8px; height: 8px; border-radius: 50%; }
.kb-count {
font-size: 11px; background: var(–surface2); border-radius: 10px;
padding: 1px 8px; color: var(–text3); margin-left: auto;
}
.kb-card {
background: var(–surface2); border: 1px solid var(–border2);
border-radius: var(–radius-xs); padding: 10px; margin-bottom: 8px;
cursor: grab; transition: all .2s;
}
.kb-card:hover { border-color: #60a5fa; transform: translateY(-1px); }
.kb-card.dragging { opacity: .45; transform: rotate(1.5deg); }
.kb-mat-tag {
font-family: ‘Outfit’,sans-serif; font-size: 10px; font-weight: 700;
padding: 2px 7px; border-radius: 4px; display: inline-block;
margin-bottom: 6px; color: #000;
}
.kb-title { font-size: 12px; font-weight: 500; color: var(–text); line-height: 1.4; margin-bottom: 6px; }
.kb-footer { display: flex; align-items: center; gap: 5px; flex-wrap: wrap; }
.kb-actions { display: flex; gap: 5px; padding-top: 7px; border-top: 1px solid var(–border); margin-top: 6px; }
.kb-select {
font-family: ‘DM Sans’,sans-serif; font-size: 11px;
background: var(–surface3); border: 1px solid var(–border2);
color: var(–text2); border-radius: 4px; padding: 3px 6px;
cursor: pointer; flex: 1;
}
.kb-icon-btn {
background: none; border: 1px solid var(–border2);
color: var(–text3); border-radius: 4px; padding: 3px 7px;
font-size: 11px; cursor: pointer; transition: .2s;
}
.kb-icon-btn:hover { border-color: #f87171; color: #f87171; }
.kb-icon-btn.edit:hover { border-color: #60a5fa; color: #60a5fa; }
.add-card-btn {
width: 100%; padding: 7px; background: none;
border: 1px dashed var(–border2); border-radius: var(–radius-xs);
color: var(–text3); font-size: 11px; cursor: pointer;
font-family: ‘DM Sans’,sans-serif; margin-top: 4px; transition: .2s;
}
.add-card-btn:hover { border-color: #60a5fa; color: #60a5fa; }

/* ── MATERIAS / CICLOS ── */
.mat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 14px; }
.mat-card {
background: var(–surface); border: 1px solid var(–border);
border-radius: var(–radius); overflow: hidden;
}
.mat-head {
padding: 12px 16px; display: flex; align-items: center; gap: 12px;
border-bottom: 1px solid var(–border);
}
.mat-strip { width: 4px; height: 44px; border-radius: 2px; flex-shrink: 0; }
.mat-name { font-family: ‘Outfit’,sans-serif; font-weight: 700; font-size: 14px; }
.mat-meta { font-size: 11px; color: var(–text3); }
.mat-lessons { padding: 4px 0 12px; }
.lesson-row {
display: flex; align-items: flex-start; gap: 10px;
padding: 7px 16px; border-bottom: 1px solid rgba(37,45,66,.5);
font-size: 12px; color: var(–text2);
}
.lesson-row:last-child { border-bottom: none; }
.lesson-num { font-family: ‘Outfit’,sans-serif; font-size: 10px; color: var(–text3); min-width: 42px; padding-top: 1px; }
.lesson-text { flex: 1; line-height: 1.4; }
.lesson-inc {
font-family: ‘Outfit’,sans-serif; font-size: 9px; font-weight: 700;
padding: 1px 6px; border-radius: 3px; flex-shrink: 0; align-self: flex-start; margin-top: 2px;
}

/* ── STATS ── */
.stats-top { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px,1fr)); gap: 14px; margin-bottom: 24px; }
.stat-card {
background: var(–surface); border: 1px solid var(–border);
border-radius: var(–radius); padding: 18px;
}
.stat-lbl { font-size: 11px; color: var(–text3); font-family: ‘Outfit’,sans-serif; margin-bottom: 4px; }
.stat-val { font-family: ‘Outfit’,sans-serif; font-weight: 900; font-size: 30px; }
.stat-sub { font-size: 11px; color: var(–text3); margin-top: 3px; }
.prog-bar { height: 5px; background: var(–surface3); border-radius: 3px; overflow: hidden; margin-top: 8px; }
.prog-fill { height: 100%; border-radius: 3px; transition: width .5s ease; }

.stat-row {
display: flex; align-items: center; gap: 12px;
padding: 9px 0; border-bottom: 1px solid rgba(37,45,66,.5);
}
.stat-row:last-child { border-bottom: none; }
.stat-row-name { font-size: 12px; font-weight: 500; min-width: 230px; }
.stat-row-bar { flex: 1; }
.stat-row-pct {
font-family: ‘Outfit’,sans-serif; font-size: 12px;
color: var(–text3); min-width: 70px; text-align: right;
}

/* ── TEMPO ── */
.tempo-week {
background: var(–surface); border: 1px solid var(–border);
border-radius: var(–radius); margin-bottom: 10px; overflow: hidden;
}
.tempo-week-head {
padding: 11px 16px; background: var(–surface2); border-bottom: 1px solid var(–border);
display: flex; justify-content: space-between; align-items: center; cursor: pointer;
}
.tempo-week-name { font-family: ‘Outfit’,sans-serif; font-weight: 700; font-size: 13px; }
.tempo-week-total { font-size: 12px; color: var(–text2); font-family: ‘Outfit’,sans-serif; font-weight: 600; }
.collapse-arrow { transition: transform .2s; }
.collapsed .collapse-arrow { transform: rotate(-90deg); }
.collapsed .tempo-week-body { display: none; }

.tempo-day-block { border-bottom: 1px solid var(–border); }
.tempo-day-block:last-child { border-bottom: none; }
.tempo-day-head {
padding: 8px 16px; background: rgba(255,255,255,.015);
display: flex; justify-content: space-between; align-items: center;
font-size: 12px;
}
.tempo-day-nm { font-family: ‘Outfit’,sans-serif; font-weight: 600; color: var(–text2); }
.tempo-day-tot { color: var(–text3); }

.tempo-entry-wrap { padding: 4px 16px 10px; }
.tempo-col-heads {
display: grid;
grid-template-columns: 1fr 78px 78px 78px 78px;
gap: 6px; padding: 4px 0 6px;
border-bottom: 1px solid var(–border);
margin-bottom: 4px;
}
.tempo-col-head { font-family: ‘Outfit’,sans-serif; font-size: 10px; font-weight: 600; color: var(–text3); text-transform: uppercase; letter-spacing: .05em; text-align: center; }
.tempo-col-head:first-child { text-align: left; }

.tempo-row {
display: grid;
grid-template-columns: 1fr 78px 78px 78px 78px;
gap: 6px; align-items: center;
padding: 5px 0; border-bottom: 1px solid rgba(37,45,66,.3);
}
.tempo-row:last-child { border-bottom: none; }
.tempo-mat-lbl { font-size: 12px; font-weight: 600; font-family: ‘Outfit’,sans-serif; }
.tempo-inp {
font-family: ‘DM Sans’,sans-serif; font-size: 12px;
background: var(–surface2); border: 1px solid var(–border2);
color: var(–text); border-radius: 5px; padding: 4px 6px;
text-align: center; width: 100%;
}
.tempo-inp:focus { outline: none; border-color: #60a5fa; }
.acerto-badge {
font-family: ‘Outfit’,sans-serif; font-size: 11px; font-weight: 700;
padding: 3px 6px; border-radius: 4px; text-align: center; width: 100%;
}
.ac-red { background: rgba(248,113,113,.18); color: #f87171; }
.ac-yel { background: rgba(251,191,36,.18); color: #fbbf24; }
.ac-grn { background: rgba(74,222,128,.18); color: #4ade80; }
.ac-non { background: var(–surface2); color: var(–text3); }

/* ── MODAL ── */
.modal-bg {
display: none; position: fixed; inset: 0;
background: rgba(0,0,0,.75); z-index: 500;
align-items: center; justify-content: center;
}
.modal-bg.open { display: flex; }
.modal {
background: var(–surface); border: 1px solid var(–border2);
border-radius: var(–radius); padding: 24px;
width: 100%; max-width: 480px;
}
.modal-title { font-family: ‘Outfit’,sans-serif; font-weight: 700; font-size: 16px; margin-bottom: 16px; }
.modal-inp, .modal-sel, .modal-ta {
width: 100%; font-family: ‘DM Sans’,sans-serif; font-size: 13px;
background: var(–surface2); border: 1px solid var(–border2);
color: var(–text); border-radius: var(–radius-xs);
padding: 9px 12px; margin-bottom: 10px;
}
.modal-ta { min-height: 70px; resize: vertical; }
.modal-inp:focus, .modal-sel:focus, .modal-ta:focus { outline: none; border-color: #60a5fa; }
.modal-lbl { font-size: 11px; color: var(–text3); font-family: ‘Outfit’,sans-serif; font-weight: 600; margin-bottom: 4px; display: block; }
.modal-row { display: flex; gap: 8px; }
.modal-row > * { flex: 1; }
.modal-btns { display: flex; gap: 8px; justify-content: flex-end; margin-top: 6px; }
.btn-prim { font-family: ‘Outfit’,sans-serif; font-weight: 700; font-size: 13px; padding: 8px 18px; background: #60a5fa; color: #000; border: none; border-radius: var(–radius-xs); cursor: pointer; transition: .2s; }
.btn-prim:hover { background: #93c5fd; }
.btn-ghost { font-family: ‘Outfit’,sans-serif; font-weight: 600; font-size: 13px; padding: 8px 18px; background: none; color: var(–text3); border: 1px solid var(–border2); border-radius: var(–radius-xs); cursor: pointer; transition: .2s; }
.btn-ghost:hover { color: var(–text2); }
.btn-danger { font-family: ‘Outfit’,sans-serif; font-weight: 700; font-size: 13px; padding: 8px 18px; background: rgba(248,113,113,.15); color: #f87171; border: 1px solid rgba(248,113,113,.3); border-radius: var(–radius-xs); cursor: pointer; transition: .2s; }
.btn-danger:hover { background: rgba(248,113,113,.3); }

/* week title bar */
.week-title-bar { margin-bottom: 16px; }
.week-title { font-family: ‘Outfit’,sans-serif; font-weight: 800; font-size: 20px; }
.week-subtitle { font-size: 12px; color: var(–text3); margin-top: 3px; }

/* scrollbar */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: var(–surface); }
::-webkit-scrollbar-thumb { background: var(–border2); border-radius: 3px; }

/* ── REVISÃO FGV ── */
.rev-section { margin-bottom: 28px; }
.rev-section-title {
display: flex; align-items: center; gap: 10px;
font-family: ‘Outfit’,sans-serif; font-weight: 800; font-size: 15px;
margin-bottom: 14px; padding-bottom: 10px;
border-bottom: 2px solid;
}
.rev-section-count {
font-family: ‘Outfit’,sans-serif; font-size: 11px; font-weight: 700;
padding: 2px 10px; border-radius: 10px; margin-left: auto;
}
.rev-items-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px,1fr)); gap: 10px; }
.rev-item {
background: var(–surface); border: 1px solid var(–border);
border-radius: var(–radius-sm); padding: 12px 14px;
display: flex; align-items: flex-start; gap: 10px;
cursor: pointer; transition: all .2s; position: relative;
}
.rev-item:hover { border-color: var(–border2); transform: translateY(-1px); }
.rev-item.dominado { background: rgba(74,222,128,.05); border-color: rgba(74,222,128,.25); }
.rev-item.revisar  { background: rgba(251,191,36,.05); border-color: rgba(251,191,36,.25); }
.rev-item.fragil   { background: rgba(248,113,113,.05); border-color: rgba(248,113,113,.25); }
.rev-check {
width: 22px; height: 22px; border-radius: 6px; border: 2px solid var(–border2);
display: flex; align-items: center; justify-content: center;
flex-shrink: 0; margin-top: 1px; font-size: 13px; transition: all .2s;
}
.rev-item.dominado .rev-check { background: #4ade80; border-color: #4ade80; }
.rev-item.revisar  .rev-check { background: #fbbf24; border-color: #fbbf24; }
.rev-item.fragil   .rev-check { background: #f87171; border-color: #f87171; }
.rev-item-body { flex: 1; min-width: 0; }
.rev-item-mat {
font-family: ‘Outfit’,sans-serif; font-size: 10px; font-weight: 700;
