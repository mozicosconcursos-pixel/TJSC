function renderStats(){
  const total = lessons.length;
  const fin = lessons.filter(l=>l.status==='Finalizado').length;
  const ini = lessons.filter(l=>l.status==='Iniciado').length;
  const rev = lessons.filter(l=>l.status==='Revisar').length;
  const sims = lessons.filter(l=>l.isSimulado&&l.status==='Finalizado').length;
  const pct = total?Math.round(fin/total*100):0;

  document.getElementById('stats-top').innerHTML = `
    <div class="stat-card"><div class="stat-lbl">Total de Aulas</div><div class="stat-val" style="color:#60a5fa">${total}</div><div class="stat-sub">planejadas</div></div>
    <div class="stat-card"><div class="stat-lbl">Finalizadas</div><div class="stat-val" style="color:#4ade80">${fin}</div><div class="stat-sub">${pct}% concluído</div><div class="prog-bar"><div class="prog-fill" style="width:${pct}%;background:#4ade80"></div></div></div>
    <div class="stat-card"><div class="stat-lbl">Em Progresso</div><div class="stat-val" style="color:#60a5fa">${ini}</div><div class="stat-sub">iniciadas</div></div>
    <div class="stat-card"><div class="stat-lbl">Para Revisar</div><div class="stat-val" style="color:#fbbf24">${rev}</div><div class="stat-sub">aguardando revisão</div></div>
    <div class="stat-card"><div class="stat-lbl">Simulados Feitos</div><div class="stat-val" style="color:#fb923c">${sims}</div><div class="stat-sub">de ${lessons.filter(l=>l.isSimulado).length}</div></div>
  `;

  const maxQ = Math.max(...MATS.map(m=>ALL_LESSONS[m.id]?.length||0));
  document.getElementById('stats-mat').innerHTML = MATS.map(m => {
    const mt = lessons.filter(l=>l.mat===m.id);
    const mf = mt.filter(l=>l.status==='Finalizado').length;
    const mp = mt.length?Math.round(mf/mt.length*100):0;
    const barW = mt.length?Math.round(mt.length/maxQ*100):0;
    return `<div class="stat-row">
      <div class="stat-row-name"><span style="color:${m.color};font-family:'Outfit',sans-serif;font-weight:600">${m.name}</span></div>
      <div class="stat-row-bar"><div class="prog-bar"><div class="prog-fill" style="width:${mp}%;background:${m.color}"></div></div></div>
      <div class="stat-row-pct" style="color:${mp>=80?'#4ade80':mp>=50?'#fbbf24':'var(--text3)'}">${mf}/${mt.length} (${mp}%)</div>
    </div>`;
  }).join('');

  document.getElementById('stats-week').innerHTML = WEEKS_META.map((w,wi) => {
    const wt = lessons.filter(l=>l.week===wi);
    const wf = wt.filter(l=>l.status==='Finalizado').length;
    const wp = wt.length?Math.round(wf/wt.length*100):0;
    return `<div class="stat-row">
      <div class="stat-row-name">${w.label}</div>
      <div class="stat-row-bar"><div class="prog-bar"><div class="prog-fill" style="width:${wp}%;background:${w.revision?'#fb923c':'#60a5fa'}"></div></div></div>
      <div class="stat-row-pct">${wf}/${wt.length} (${wp}%)</div>
    </div>`;
  }).join('');
}

