function openAdd(){
  editId=null;
  document.getElementById('modal-add-title').textContent='Nova Aula';
  document.getElementById('ma-title').value='';
  document.getElementById('ma-mat').innerHTML=MATS.map(m=>`<option value="${m.id}">${m.name}</option>`).join('');
  document.getElementById('ma-week').innerHTML=WEEKS_META.map((w,i)=>`<option value="${i}">${w.label}</option>`).join('');
  document.getElementById('ma-week').value=curWeek;
  document.getElementById('ma-imp').value='Alta';
  document.getElementById('modal-add').classList.add('open');
}

function openEdit(id){
  const l=lessons.find(x=>x.id===id); if(!l) return;
  editId=id;
  document.getElementById('modal-add-title').textContent='Editar Aula';
  document.getElementById('ma-title').value=`${l.lessonNum} — ${l.title}`;
  document.getElementById('ma-mat').innerHTML=MATS.map(m=>`<option value="${m.id}">${m.name}</option>`).join('');
  document.getElementById('ma-mat').value=l.mat;
  document.getElementById('ma-week').innerHTML=WEEKS_META.map((w,i)=>`<option value="${i}">${w.label}</option>`).join('');
  document.getElementById('ma-week').value=l.week;
  document.getElementById('ma-day').value=l.day;
  document.getElementById('ma-imp').value=l.importance;
  document.getElementById('modal-add').classList.add('open');
}

function saveLesson(){
  const title=document.getElementById('ma-title').value.trim();
  const matId=document.getElementById('ma-mat').value;
  const week=parseInt(document.getElementById('ma-week').value);
  const day=parseInt(document.getElementById('ma-day').value);
  const imp=document.getElementById('ma-imp').value;
  if(!title||!matId||isNaN(week)||isNaN(day)){alert('Preencha todos os campos!');return;}

  // Split into lessonNum and title if possible
  const parts=title.split(' — ');
  const lNum=parts.length>1?parts[0]:title;
  const lTitle=parts.length>1?parts.slice(1).join(' — '):title;

  if(editId){
    const l=lessons.find(x=>x.id===editId);
    if(l){Object.assign(l,{mat:matId,lessonNum:lNum,title:lTitle,week,day,importance:imp});}
  } else {
    const newId=Math.max(0,...lessons.map(l=>l.id))+1;
    lessons.push({id:newId,mat:matId,lessonNum:lNum,title:lTitle,week,day,importance:imp,status:'Não Iniciado',method:'Aula',isSimulado:false});
  }
  saveLessons();
  closeModal('modal-add');
  renderPlano();
}

function openDel(id){
  delId=id;
  const l=lessons.find(x=>x.id===id);
  document.getElementById('del-name').textContent=l?`${l.lessonNum} — ${l.title}`:'';
  document.getElementById('modal-del').classList.add('open');
}
function confirmDel(){
  lessons=lessons.filter(x=>x.id!==delId);
  saveLessons(); closeModal('modal-del'); renderPlano(); renderStats();
}
function closeModal(id){ document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.modal-bg').forEach(bg=>{
  bg.addEventListener('click',e=>{ if(e.target===bg) bg.classList.remove('open'); });
});

